{
  "expo": {
    "name": "Eversweet",
    "slug": "eversweet_app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ios-light.png",
    "scheme": "eversweet",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "extra": {
      "eas": {
        "projectId": "c393dcac-7d8e-424c-9c79-d13a5085ffc8"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "nz.co.eversweet",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "This app includes camera-related libraries. We do not use the camera, but Apple requires this message.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["eversweet"]
          }
        ]
      },
      "icon": "./assets/images/ios-light.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "nz.co.eversweet",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "eversweet",
              "host": "*"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/eversweet_1024.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon-dark.png",
          "imageWidth": 400,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-secure-store",
      "expo-notifications",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "finrei127"
  }
}
