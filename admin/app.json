{
  "expo": {
    "name": "Eversweet Manager",
    "slug": "eversweet_admin",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/eversweet_1024.png",
    "scheme": "eversweetappmanager",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "androidNavigationBar": {
      "visible": "sticky-immersive"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "nz.co.eversweet.admin",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "This app uses Bluetooth to connect to thermal printers",
        "NSBluetoothPeripheralUsageDescription": "This app uses Bluetooth to connect to thermal printers",
        "UIBackgroundModes": [
          "audio",
          "fetch",
          "remote-notification",
          "bluetooth-central"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "This app includes camera-related libraries. We do not use the camera, but Apple requires this message."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/eversweet_1024.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "nz.co.eversweet.admin",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_CONNECT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/eversweet_1024.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/transparent_logo_1024.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-secure-store",
      ["expo-font"],
      "expo-audio",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": ["peripheral", "central"],
          "bluetoothAlwaysPermission": "This app uses Bluetooth to connect to thermal printers"
        }
      ],
      ["expo-screen-orientation"],
      [
        "react-native-permissions",
        {
          "ios": ["BluetoothAlways", "BluetoothPeripheral"],
          "android": [
            "BLUETOOTH_CONNECT",
            "ACCESS_FINE_LOCATION",
            "BLUETOOTH_SCAN"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "017213af-a1de-45ca-8d67-bddf66aa04ed"
      }
    },
    "owner": "finrei127"
  }
}
