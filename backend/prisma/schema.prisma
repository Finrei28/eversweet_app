generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                   String          @id @default(cuid())
  username             String?         @unique
  password             String
  email                String          @unique
  emailVerified        DateTime?
  image                String?
  role                 Role
  requires2FAExpiresAt DateTime?
  otp                  String?
  otpExpiresAt         DateTime?
  firstName            String?
  lastName             String?
  phone                String?
  stripeCustomerId     String?
  pushToken            String?
  createdAt            DateTime        @default(now())
  accounts             Account[]
  Authenticator        Authenticator[]
  cart                 Cart?
  Loyalty              Loyalty?
  membership           Membership?
  appOrders            Order[]         @relation("UserOrders")
  sessions             Session[]
}

model Membership {
  id                    String            @id @default(cuid())
  userId                String            @unique
  planId                String
  startDate             DateTime          @default(now())
  endDate               DateTime
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  isActive              Boolean           @default(false)
  cancel                Boolean           @default(false)
  stripePaymentMethodId String?
  stripeSubscriptionId  String?           @unique
  paymentStatus         PaymentStatus     @default(PENDING)
  totalMonths           Int               @default(0)
  plan                  MembershipPlan    @relation(fields: [planId], references: [id])
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  redemptions           OfferRedemption[]
}

model Offer {
  id               String            @id @default(cuid())
  name             String
  dessertId        String?
  categoryId       String?
  itemPriceInCents Int?
  discountAmount   Decimal?
  limit            Int               @default(1)
  cartItems        CartItem[]
  category         Category?         @relation(fields: [categoryId], references: [id])
  dessert          Dessert?          @relation(fields: [dessertId], references: [id])
  redemptions      OfferRedemption[]
  orderDessert     OrderDessert[]
}

model OfferRedemption {
  id           String     @id @default(cuid())
  offerId      String
  membershipId String
  redeemedAt   DateTime   @default(now())
  renewsAt     DateTime?
  used         Int        @default(0)
  membership   Membership @relation(fields: [membershipId], references: [id])
  offer        Offer      @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([offerId, membershipId])
}

model MembershipPlan {
  id            String       @id @default(cuid())
  name          String
  stripePriceId String       @unique
  memberships   Membership[]
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Dessert {
  id                     String              @id @default(cuid())
  name                   String
  chineseName            String
  description            String?
  priceInCents           Int
  imagePath              String
  imagePublicId          String
  isAvailableForPurchase Boolean             @default(false)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  categoryId             String
  priceInLoyaltyPoints   Int                 @default(500)
  cartItems              CartItem[]
  category               Category            @relation(fields: [categoryId], references: [id])
  ingredients            DessertIngredient[]
  offers                 Offer[]
  orders                 OrderDessert[]
}

model Category {
  id             String                  @id @default(cuid())
  name           String
  chineseName    String
  sortOrder      Int?
  customisations CategoryCustomisation[]
  desserts       Dessert[]
  offers         Offer[]
}

model Ingredient {
  id                      String                      @id @default(cuid())
  name                    String
  chineseName             String
  priceInCents            Int
  isAvailableForPurchase  Boolean                     @default(false)
  categories              CategoryCustomisation[]
  customisationInCartItem CustomisationInCartItem[]
  DessertIngredient       DessertIngredient[]
  orderCustomisations     OrderDessertCustomisation[]
}

model DessertIngredient {
  dessertId    String
  ingredientId String
  dessert      Dessert    @relation(fields: [dessertId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@id([dessertId, ingredientId])
}

model CategoryCustomisation {
  id              String     @id @default(cuid())
  categoryId      String
  customisationId String
  category        Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  customisation   Ingredient @relation(fields: [customisationId], references: [id], onDelete: Cascade)

  @@unique([categoryId, customisationId])
}

model TempOrderCounter {
  id      String   @id @default(cuid())
  date    DateTime @unique
  counter Int
}

model Order {
  id                  String         @id @default(cuid())
  tempOrderId         String
  priceInCents        Int
  discountedAmountInCents  Int       @default(0)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  customerFirstName   String
  customerLastName    String
  customerEmail       String
  customerPhoneNumber String?
  completedAt         DateTime?
  pickedUpAt          DateTime?
  status              Status
  dineIn              Boolean        @default(false)
  pickUpTime          DateTime       @default(now())
  GST                 Int
  appUserId           String?
  source              OrderSource    @default(WEBSITE)
  paymentIntentId     String?
  paymentMethodId     String?
  notified            Boolean        @default(false)
  appUser             User?          @relation("UserOrders", fields: [appUserId], references: [id])
  desserts            OrderDessert[]

  @@index([status])
}

model OrderDessertCustomisation {
  id              String       @id @default(cuid())
  orderDessertId  String
  customisationId String
  quantity        Int          @default(1)
  customisation   Ingredient   @relation(fields: [customisationId], references: [id], onDelete: Cascade)
  orderDessert    OrderDessert @relation(fields: [orderDessertId], references: [id], onDelete: Cascade)
}

model OrderDessert {
  id                String                      @id @default(cuid())
  orderId           String
  dessertId         String
  offerId           String?
  quantity          Int
  priceInCents      Int                         @default(0)
  discountedAmountInCents  Int                  @default(0)
  loyaltyPointsUsed Int?
  dessert           Dessert                     @relation(fields: [dessertId], references: [id])
  order             Order                       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  offer             Offer?                    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  customisations    OrderDessertCustomisation[]

  @@unique([orderId, dessertId, id])
}

model Feedback {
  id              String   @id @default(cuid())
  rating          Int
  createdAt       DateTime @default(now())
  feedbackMessage String
  name            String?
  email           String
}

model Loyalty {
  id     String @id @default(cuid())
  points Int
  userId String @unique
  User   User   @relation(fields: [userId], references: [id])
  records LoyaltyRecord[]
}

model LoyaltyRecord {
  id         String   @id @default(cuid())
  change     Int      // positive = earned, negative = spent
  reason     String
  createdAt  DateTime @default(now())

  loyaltyId  String
  loyalty    Loyalty  @relation(fields: [loyaltyId], references: [id])
}

model Cart {
  id                     String     @id @default(cuid())
  userId                 String     @unique
  createdAt              DateTime   @default(now())
  expiresAt              DateTime?
  totalLoyaltyPointsUsed Int        @default(0)
  totalPriceInCents      Int        @default(0)
  user                   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cartItems              CartItem[]
}

model CartItem {
  id                          String                    @id @default(cuid())
  dessertId                   String
  itemPriceInCents            Int
  discountedAmountInCents     Int                       @default(0)
  isPromotionItem             Boolean                   @default(false)
  promotionType               String?
  createdAt                   DateTime                  @default(now())
  quantity                    Int
  loyaltyPointsUsed           Int?
  cartId                      String
  offerId                     String?
  cart                        Cart                      @relation(fields: [cartId], references: [id], onDelete: Cascade)
  dessert                     Dessert                   @relation(fields: [dessertId], references: [id])
  offer                       Offer?                    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  customisations              CustomisationInCartItem[]

  @@unique([cartId, promotionType, dessertId])
}

model CustomisationInCartItem {
  id              String     @id @default(cuid())
  cartItemId      String
  customisationId String
  quantity        Int        @default(1)
  cartItem        CartItem   @relation(fields: [cartItemId], references: [id], onDelete: Cascade)
  customisation   Ingredient @relation(fields: [customisationId], references: [id], onDelete: Cascade)

  @@unique([cartItemId, customisationId])
}

model RestaurantStatus {
  id                  String    @id @default(cuid())
  dineInAvailability  Boolean
  unavailableUntil    DateTime?
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum Role {
  ADMIN
  USER
}

enum OrderSource {
  WEBSITE
  APP
}

enum Status {
  PENDING
  ACCEPTED
  MAKING
  READY
  PICKED_UP
}

enum IngredientType {
  MOCHI
  GLUTINOUS_BALLS
  OSMANTHUS
  TARO
  MANGO
  PURPLE_RICE
  GRAPES
  BOBA
  RED_BEANS
  SAGO
  COCONUT_JELLY
  GRASS_JELLY
  TARO_CREAM
  SNOW_SWALLOW
  PEACH_GUM
  COCONUT_MILK
  MILK_PUDDING
  BLACK_SESAME
  PEANUT
  MUNG_BEAN
  PISTACHIO
  PUMPKIN
  TARO_BALLS
  SWEET_POTATO
  NOODLES
  BROWN_SUGAR
  TOFU
  DURIAN
}
